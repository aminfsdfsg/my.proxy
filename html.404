<!DOCTYPE html>
<html>
<head>
    <title>Your Proxy Router</title>
    <script>
        // این پروکسی از کلودفلر ورکر خودت استفاده می‌کنه
        const YOUR_GATEWAY = "https://api.allorigins.win/raw?url="; 
        
        async function handleRequest() {
            const path = window.location.pathname.substring(1);
            if (!path) {
                document.body.innerHTML = '<h1>آدرس سایت رو بعد از / بنویس</h1><p>مثال: aminfsdfsg.github.io/my.proxy/https://google.com</p>';
                return;
            }
            
            try {
                const response = await fetch(YOUR_GATEWAY + path);
                if (!response.ok) throw new Error('Network response was not ok');
                
                const html = await response.text();
                document.open();
                document.write(html);
                document.close();
            } catch (error) {
                document.body.innerHTML = `<h1>خطا در بارگذاری</h1><p>${error.message}</p>`;
            }
        }
        window.onload = handleRequest;
    </script>
</head>
<body><h1>در حال بارگذاری...</h1></body>
</html>
